# ==============================================================================
# 全局设置
# ==============================================================================
# 自动处理文本文件的换行符
* text=auto

# ==============================================================================
# Java相关文件
# ==============================================================================
*.java text diff=java eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Maven文件
pom.xml text eol=lf
*.pom text eol=lf

# ==============================================================================
# 前端文件
# ==============================================================================
# JavaScript/TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf

# 样式文件
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf

# HTML
*.html text eol=lf
*.htm text eol=lf

# JSON
*.json text eol=lf

# ==============================================================================
# 配置和文档文件
# ==============================================================================
*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.config text eol=lf
*.ini text eol=lf

# Git配置
.gitignore text eol=lf
.gitattributes text eol=lf

# 构建配置
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradle.properties text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf

# ==============================================================================
# 二进制文件
# ==============================================================================
# Java编译产物
*.class binary
*.jar binary
*.war binary
*.ear binary

# 压缩文件
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.7z binary

# 图片文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.svg text eol=lf
*.webp binary

# 字体文件
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# 其他二进制文件
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# ==============================================================================
# Linguist语言检测
# ==============================================================================
# 确保正确识别项目语言
**/src/main/java/**/*.java linguist-language=Java
**/src/main/resources/**/*.xml linguist-language=XML
**/src/main/resources/**/*.properties linguist-language=Properties
**/src/main/resources/**/*.yml linguist-language=YAML
**/src/main/resources/**/*.yaml linguist-language=YAML

# 前端语言识别
**/src/**/*.vue linguist-language=Vue
**/src/**/*.ts linguist-language=TypeScript
**/src/**/*.tsx linguist-language=TypeScript
**/src/**/*.js linguist-language=JavaScript
**/src/**/*.jsx linguist-language=JavaScript

# 排除生成的文件
**/target/** linguist-generated=true
**/node_modules/** linguist-generated=true
**/dist/** linguist-generated=true
**/build/** linguist-generated=true 